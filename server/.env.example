# Copy to server/.env and fill in. The dev/migrate npm scripts pass this
# file to tsx via --env-file, so values land in process.env automatically.

# Postgres connection string (Zeabur DB or any reachable Postgres)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Bearer token used by scripts/push.py to authenticate writes
API_TOKEN=change-me-to-something-long

# OpenAI-compatible endpoint for analysis
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=sk-...
LLM_MODEL_ID=your-model-id

# Optional
LLM_PROVIDER_NAME=custom
LLM_CONCURRENCY=2
PORT=8000
